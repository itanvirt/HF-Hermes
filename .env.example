# Copy this file to .env for local development.
# On Hugging Face, set these as Space secrets instead (Settings -> Variables and secrets).

# Hugging Face access token (write access). Used to create/update the backup
# dataset repo and to look up your HF username.
HF_TOKEN=

# Cloudflare API token with "Edit Cloudflare Workers" permission.
# Used by the Cloudflare Worker (Telegram proxy + keep-awake cron) deploy step.
CLOUDFLARE_WORKERS_TOKEN=

# Comma-separated list of Telegram user IDs allowed to talk to the agent.
TELEGRAM_ALLOWED_USERS=

# Telegram bot token from @BotFather.
TELEGRAM_BOT_TOKEN=

# Shared secret used to protect the gateway API, the web terminal and the
# ENV Builder. Pick a long random string.
GATEWAY_TOKEN=

# LLM model identifier passed to Hermes Agent, e.g. gemini-2.5-flash,
# gpt-4o-mini, claude-sonnet-4-6, openrouter/...
LLM_MODEL=gemini-2.5-flash

# API key for the provider implied by LLM_MODEL.
LLM_API_KEY=
